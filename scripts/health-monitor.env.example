# Copy to health-monitor.env and fill in. NEVER commit the real file.
#   cp scripts/health-monitor.env.example scripts/health-monitor.env

# What to probe
API_BASE=https://api.bdranks.com/api/v1
ENDPOINTS="/stats /reviews?limit=1 /products?limit=1 /categories"

# Where the API container lives (for log scanning / restart)
COMPOSE_FILE=/home/deploy/reviewhub/be/docker-compose.prod.yml
SERVICE=api

# ── Alerting ──────────────────────────────────────────────────────────────────
# Pick ONE channel.

# Slack or Mattermost incoming webhook:
WEBHOOK_KIND=slack
WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# Discord webhook (uncomment):
# WEBHOOK_KIND=discord
# WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Telegram bot (uncomment):
# WEBHOOK_KIND=telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# ── Behavior ──────────────────────────────────────────────────────────────────
# Restart the container automatically on a hard outage (000/502/503/504).
AUTO_RESTART=false
RESTART_COOLDOWN=900     # min seconds between auto-restarts

ALERT_REPEAT=1800        # don't repeat the same alert more often than this (sec)
LOG_WINDOW=5m            # how far back to scan logs on failure
