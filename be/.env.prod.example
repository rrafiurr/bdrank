# Copy this file to .env.prod and fill in real values before deploying.
# NEVER commit .env.prod to git.

PORT=8080
BASE_URL=https://api.bdranks.com
SITE_URL=https://bdranks.com

# Restrict CORS to your actual frontend domains (comma-separated)
ALLOWED_ORIGINS=https://bdranks.com,https://www.bdranks.com,https://cms.bdranks.com

# Database — local MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=reviewhub
DB_PASSWORD=CHANGE_TO_STRONG_DB_PASSWORD
DB_NAME=reviewhub

# Redis — local Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=CHANGE_TO_STRONG_REDIS_PASSWORD
REDIS_DB=0

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_TO_64_CHAR_RANDOM_HEX_STRING
TOKEN_TTL=24h

# File uploads
UPLOAD_DIR=/home/deploy/reviewhub/uploads

# External API (Google Reviews import script)
EXTERNAL_USER=external_admin
EXTERNAL_PASS=CHANGE_TO_STRONG_SECRET
