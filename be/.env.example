# Server
PORT=8080
BASE_URL=http://localhost:8080

# MySQL (already installed on this machine)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=finalreview

# Redis (already installed on this machine)
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT  — change this to a long random secret in production
JWT_SECRET=replace-with-a-strong-random-secret

# File upload directory (relative or absolute)
UPLOAD_DIR=./uploads
